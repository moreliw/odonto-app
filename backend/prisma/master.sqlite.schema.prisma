generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client-master"
}

datasource db {
  provider = "sqlite"
  url      = env("MASTER_SQLITE_URL")
}

// SQLite não suporta enum nativo; armazenamos como String

model Tenant {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  subdomain   String   @unique
  dbName      String
  dbHost      String
  dbPort      Int      @default(5432)
  dbUser      String
  dbPassword  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  subscription Subscription?
  loginIdentities LoginIdentity[]
}

model Subscription {
  id           String              @id @default(uuid())
  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  tenantId     String              @unique
  plan         String
  status       String              @default("ACTIVE")
  priceCents   Int
  currency     String              @default("BRL")
  startedAt    DateTime            @default(now())
  renewsAt     DateTime?
  canceledAt   DateTime?
}

model LoginIdentity {
  id        String  @id @default(uuid())
  email     String  @unique
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  tenantId  String
  createdAt DateTime @default(now())
}
