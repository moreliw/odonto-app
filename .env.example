# Copie para .env no servidor (ou use o deploy via GitHub Actions com secrets).
# Substitua SEU_IP pelo host público (ex.: 62.171.161.221) ou pelo domínio.

POSTGRES_USER=odonto
POSTGRES_PASSWORD=mude-esta-senha
MASTER_DATABASE_URL=postgresql://odonto:mude-esta-senha@postgres-master:5432/master?schema=public

JWT_SECRET=gere-um-segredo-longo
JWT_REFRESH_SECRET=gere-outro-segredo-longo
LOG_LEVEL=info
LOG_TO_FILE=false

REDIS_URL=redis://redis:6379

S3_ACCESS_KEY=minio
S3_SECRET_KEY=mude-esta-senha-minio
S3_BUCKET=odonto-files
# URL que o navegador e o backend usam para MinIO (porta publicada no compose: 9000).
S3_ENDPOINT=http://SEU_IP:9000

# Obrigatório ao acessar por IP ou domínio sem subdomínio (ex.: clinica.seudominio.com).
# Use o subdomínio da clínica cadastrado no banco (após signup ou painel master).
DEV_TENANT_SUBDOMAIN=

MASTER_ADMIN_TOKEN=

# Login do painel master (/admin/login); altere em produção.
MASTER_SUPERADMIN_EMAIL=admin@odontoapp.com
MASTER_SUPERADMIN_PASSWORD=Admin@123456

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

PUBLIC_DOMAIN=
PUBLIC_WILDCARD=
